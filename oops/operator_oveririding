class Point:
    def __init__(self,x,y):
        self.x = x
        self.y = y
    
    def sum(self, p):
        return Point((self.x + p.x), (self.y + p.y))
    
    def __add__(self, p):
        return Point((self.x +p.x), (self.y + p.y))
    

p1 = Point(3,2)
p2 = Point(5,7)
result = p1.sum(p2)
print(f"Result x: {result.x}, y: {result.y}")

p = p1 + p2
print(f"Point p x: {p.x}, y: {p.y}")

